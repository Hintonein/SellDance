    "dev:frontend": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "seed:mock": "node backend/scripts/seed-mock-data.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hintonein/SellDance.git"
  },
