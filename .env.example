# SellDance local environment example.
# Copy to .env for local development. Never commit real API keys.

# Provider switches. Mock providers must remain available for local development.
# Shared Volcengine Ark settings
ARK_API_KEY=
SEEDANCE_MODEL=
SEEDANCE_ENDPOINT_ID=
SEED_ENDPOINT_ID=
SEEDREAM_MODEL=
ARK_BASE_URL=https://ark.cn-beijing.volces.com
AI_SCRIPT_PROVIDER=seed2
AI_STORYBOARD_PROVIDER=seed2
AI_IMAGE_PROVIDER=disabled
AI_AGENT_PROVIDER=mock
AI_ASSET_ANALYSIS_PROVIDER=seed2
AI_ANALYSIS_PROVIDER=seed2
AI_VIDEO_PROVIDER=seedance
ARK_POLL_ATTEMPTS=120
ARK_POLL_INTERVAL_MS=5000




# Optional test hook for provider development. Should not be used in production.
ARK_MOCK_REMOTE_URL=
