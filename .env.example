# SellDance local environment example.
# Copy to .env for local development. Never commit real API keys.

# Provider switches. Mock providers must remain available for local development.
AI_SCRIPT_PROVIDER=mock
AI_STORYBOARD_PROVIDER=mock
AI_ANALYSIS_PROVIDER=mock
AI_ASSET_ANALYSIS_PROVIDER=mock
AI_VIDEO_PROVIDER=mock
AI_IMAGE_PROVIDER=disabled
AI_AGENT_PROVIDER=mock

# Shared Volcengine Ark settings
ARK_BASE_URL=https://ark.cn-beijing.volces.com
ARK_API_KEY=
ARK_MODEL=

# Seed 2.0 / text understanding / script / classification / multimodal analysis provider
SEED2_API_KEY=
SEED2_MODEL=
SEED2_ENDPOINT_ID=
SEED_ENDPOINT_ID=
SEED_CLASSIFICATION_ENDPOINT_ID=

# Seedance text-to-video provider
SEEDDANCE_API_KEY=
SEEDDANCE_MODEL=
SEEDDANCE_ENDPOINT_ID=
SEEDANCE_MODEL=
SEEDANCE_ENDPOINT_ID=

# Seedream image provider. Keep disabled until account access and product scope are confirmed.
SEEDREAM_API_KEY=
SEEDREAM_MODEL=
SEEDREAM_ENDPOINT_ID=

# Ark async polling
ARK_POLL_ATTEMPTS=24
ARK_POLL_INTERVAL_MS=5000

# Optional test hook for provider development. Should not be used in production.
ARK_MOCK_REMOTE_URL=
